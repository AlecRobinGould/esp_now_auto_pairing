{
  "name": "esp-now-auto-pairing",
  "version": "1.0.0",
  "description": "Automatic ESP-NOW pairing library for ESP32. Handles device discovery, pairing negotiation, and NVS persistence.",
  "keywords": [
    "esp32",
    "esp-now",
    "pairing",
    "wireless",
    "networking",
    "auto-pairing",
    "embedded",
    "mesh"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alecrobingould/esp-now-auto-pairing-lib.git"
  },
  "authors": [
    {
      "name": "Alec",
      "email": "argould2277@gmail.com",
      "url": "https://github.com/alecrobingould",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "homepage": "https://github.com/alecrobingould/esp-now-auto-pairing-lib",
  "frameworks": "espidf",
  "platforms": [
    "espressif32"
  ],
  "build": {
    "srcFilter": [
      "+<src/>",
      "+<include/>",
      "-<examples/>"
    ]
  },
  "export": {
    "include": [
      "include/"
    ],
    "exclude": [
      "examples/",
      "test/",
      ".vscode/",
      ".pio/",
      "build/"
    ]
  }
}